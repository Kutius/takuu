    "up": "pnpx taze@latest -I"
  },
  "dependencies": {
    "@takumi-rs/core": "^1.0.0-beta.16",
    "@takumi-rs/helpers": "^1.0.0-beta.16",
    "@takumi-rs/image-response": "^1.0.0-beta.16",
    "cac": "^7.0.0",
    "lucide-react": "^1.6.0",
    "oxc-transform": "^0.121.0",
    "picocolors": "^1.1.1",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "eslint": "^10.1.0",
    "tsdown": "^0.21.4",
    "typescript": "^6.0.2"
  }
}
