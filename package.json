{
  "name": "takuu",
  "type": "module",
  "version": "0.1.0",
  "description": "JSX → Image CLI. Render React components to images using Takumi.",
  "author": "",
  "license": "MIT",
  "bin": {
    "takuu": "dist/cli.mjs"
  },
  "exports": {
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
